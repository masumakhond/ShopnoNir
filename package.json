{
  "name": "investment_cooperative",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "dev:fresh": "lsof -ti:3000,3001 | xargs kill -9 2>/dev/null; rm -rf .next && next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --force-reset && npm run db:seed",
    "db:migrate-tracking": "tsx prisma/migrate-tracking-id.ts",
    "db:migrate-pools": "tsx prisma/migrate-capital-pools.ts",
    "db:restore-investments": "tsx prisma/restore-investment-data.ts",
    "members:rename": "tsx prisma/update-member-names.ts",
    "db:seed": "tsx prisma/seed.ts",
    "admin:reset": "tsx prisma/reset-admin.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^3.6.0",
    "jose": "^6.2.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5"
  }
}
